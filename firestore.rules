rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isEmployee() {
      return isSignedIn() && getUserRole() == 'employee';
    }

    function isStaff() {
      return isAdmin() || isEmployee();
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read any profile (needed for claim reviews, etc.)
      allow read: if isSignedIn();
      // Users can create their own profile on sign-up
      allow create: if isOwner(userId);
      // Users can update their own profile; admins can update any profile (role changes)
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // ── Items ─────────────────────────────────────────────
    match /items/{itemId} {
      // Any signed-in user can view items
      allow read: if isSignedIn();
      // Only staff can create / report items
      allow create: if isStaff();
      // Staff can update items (status, lock, etc.)
      allow update: if isStaff();
      // Only admins can delete items
      allow delete: if isAdmin();
    }

    // ── Claims ────────────────────────────────────────────
    match /claims/{claimId} {
      // Users can read their own claims; staff can read all claims
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isStaff()
      );
      // Any signed-in user can submit a claim
      allow create: if isSignedIn();
      // Staff can update claims (approve / reject); claim owner cannot self-approve
      allow update: if isStaff();
      // Only admins can delete claims
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────
    match /notifications/{notifId} {
      // Users can read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Staff can create notifications for users
      allow create: if isSignedIn();
      // Users can mark their own notifications as read
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only admins can delete notifications
      allow delete: if isAdmin();
    }

    // ── Promotion Requests ────────────────────────────────
    match /promotion_requests/{reqId} {
      // Admins can read all; users can read their own
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Any signed-in user can request a promotion
      allow create: if isSignedIn();
      // Only admins can approve / reject
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────
    match /audit_logs/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();
      // Staff can create audit log entries
      allow create: if isStaff();
      // Audit logs are immutable
      allow update, delete: if false;
    }
  }
}